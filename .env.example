# Root Docker Compose environment example.
# Copy this file to .env before running docker compose from the repository root.
# Do not commit real secrets or production/RDS values.

# Database
DB_USERNAME=root
DB_PASSWORD=1234
DB_MEMBERPOINT=memberpoint
DB_BATTLE=battle
DB_MARKET=market
DB_INSIGHT=insight

# Auth / Security
JWT_SECRET=local-jwt-secret-change-me-32chars
CRYPTO_AES_KEY=0123456789abcdef0123456789abcdef
KAKAO_CLIENT_ID=local-kakao-client-id
INTERNAL_AUTH_TOKEN=local-internal-token

# External APIs
REB_API_KEY=replace-me
REB_API_BASE_URL=replace-me

CLAUDE_API_KEY=replace-me
CLAUDE_API_URL=replace-me
CLAUDE_MODEL=replace-me
