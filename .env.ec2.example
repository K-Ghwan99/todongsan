# EC2 Docker Compose environment example.
# Copy this file to .env on EC2.
# Do not commit real secrets.
# Do not put RDS endpoints, EC2 public IPs, or production credentials here.

# Database for Docker MySQL on the same EC2
DB_USERNAME=root
DB_PASSWORD=change-me
DB_MEMBERPOINT=memberpoint
DB_BATTLE=battle
DB_MARKET=market
DB_INSIGHT=insight

# Auth / Security
JWT_SECRET=change-me-at-least-32-characters
CRYPTO_AES_KEY=change-me-32-byte-key
KAKAO_CLIENT_ID=change-me
INTERNAL_AUTH_TOKEN=change-me

# External APIs
REB_API_KEY=change-me
REB_API_BASE_URL=change-me

CLAUDE_API_KEY=change-me
CLAUDE_API_URL=change-me
CLAUDE_MODEL=change-me
